# Settings template.
# 1. Copy this file next to it and name the copy .env
# 2. Paste your own token from @BotFather instead of the example below
# The .env file is NOT committed to git (it's in .gitignore) — safe to keep secrets there.

BOT_TOKEN=123456789:AAExample-Token-From-BotFather

# Interface language for the bot's messages: en or ru (defaults to en).
BOT_LANGUAGE=en

# HTTPS URL of the Mini App form (e.g. GitHub Pages).
# Leave empty to hide the "Open form" button.
WEB_APP_URL=https://bronti.github.io/mindcontrol/

# Your Telegram user id — the ONLY person allowed to use the bot.
# Leave empty at first: run the bot, send it any message, and it prints your id
# in the log. Paste that number here and restart. Anyone else gets a warning.
OWNER_ID=

# Your medications, offered in the form's medication pickers. Kept here (not in
# the public form page) because the list is personal.
# Format: drugs separated by "; ", each optionally with its usual dose in mg —
# that dose is pre-filled (and editable) when you add the drug in the form.
# Leave empty for no fixed list: the form then only offers free-text entry.
MEDICATIONS=Aspirin 100mg; Melatonin 3mg; Vitamin D

